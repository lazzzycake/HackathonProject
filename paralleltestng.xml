<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.1.dtd" >


<suite name="suite2" thread-count="5" parallel="tests">
    <test name="ChromeTest">
        <parameter name="os" value="Windows"/>
        <parameter name="browser" value="Chrome"/>
        <classes>
            <class name="TestCases.SearchWebDevelopment"/>
            <class name="TestCases.EnterpriseForm"/>
            <class name="TestCases.ExtractAllLanguages"/>
        </classes>
    </test>

    <test name = "EdgeTest">
        <parameter name="os" value="Windows"/>
        <parameter name="browser" value="Edge"/>
        <classes>
            <class name="TestCases.SearchWebDevelopment"/>
            <class name="TestCases.EnterpriseForm"/>
            <class name="TestCases.ExtractAllLanguages"/>
        </classes>
    </test>
</suite>